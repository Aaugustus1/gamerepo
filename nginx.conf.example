# Nginx config for The Game Repository
# Place at /etc/nginx/sites-available/gamenull, then symlink to sites-enabled
# Replace `yourdomain.com` with your actual domain.

server {
    listen 80;
    server_name yourdomain.com www.yourdomain.com;

    # Static client files (index.html, admin.html, profile.html, style.css, app.js, images/, etc.)
    root /var/www/gamenull;
    index index.html;

    client_max_body_size 10M;

    # API reverse proxy
    location /api/ {
        proxy_pass http://127.0.0.1:5000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 60s;
    }

    # Uploaded images
    location /uploads/ {
        proxy_pass http://127.0.0.1:5000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
    }

    # Static assets (cached aggressively)
    location ~* \.(jpg|jpeg|png|gif|webp|avif|svg|ico|css|js)$ {
        expires 7d;
        add_header Cache-Control "public, max-age=604800";
        try_files $uri =404;
    }

    # All other routes fall through to index.html
    location / {
        try_files $uri $uri/ =404;
    }

    # Security headers
    add_header X-Content-Type-Options nosniff;
    add_header X-Frame-Options SAMEORIGIN;
    add_header Referrer-Policy no-referrer;
}
